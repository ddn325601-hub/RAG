# Required. Do not commit the real value.
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key

# Public /chat API token. Change this before public deployment.
CONTEST_API_TOKEN=replace-with-your-contest-token
KAFU_API_TOKEN=replace-with-your-contest-token

# Spring profile used for demo deployment.
SPRING_PROFILES_ACTIVE=local

# JVM memory. 8 GB ECS can use this comfortably with Milvus.
JAVA_OPTS=-Xms512m -Xmx2g
